<script language="JavaScript">
<!--

//Note: The Javascript escape and unescape functions do not correspond with what browsers actually do...

// This function decodes the  Percent encoded URL,
// Replace %xx with equivalent character
// Put [ERROR] in output if %xx is invalid.
function decode_url(url) 
{
    var HEXCHARS = "0123456789ABCDEFabcdef";
    var encoded = url;
	var plaintext = "";
	var i = 0;
	while (i < encoded.length) {
		var ch = encoded.charAt(i);

		if (ch == "%") {
			if (i < (encoded.length-2)
			&& HEXCHARS.indexOf(encoded.charAt(i+1)) != -1
			&& HEXCHARS.indexOf(encoded.charAt(i+2)) != -1 ) {
			plaintext += unescape( encoded.substr(i,3) );
			i += 3;
			} else {
			// Bad escape combination  at encoded.substr(i)
			alert('Bad Request');
			plaintext += "%[ERROR]";
			i++;
			}
		} else {
			plaintext += ch;
			i++;
		}
	} // while
return plaintext;
}

//This function performs Percent encoding on URL as per RFC 1738, However it considers following  "/:?&=" as SAFE CHARCTERS
function encode_url(url) 
{
	var SAFECHARS = "0123456789" + // Numeric
	"ABCDEFGHIJKLMNOPQRSTUVWXYZ" + // Alphabetic
	"abcdefghijklmnopqrstuvwxyz" +
	"-_.!~*'()" + // RFC2396 Mark characters and RFC 1738 special characters.
	"/:?&="; // RSA SAFE CHARCTERS

	var HEX = "0123456789ABCDEF";
	var plaintext = url;
	var encoded = "";
	
	for (var i = 0; i < plaintext.length; i++ ) {
		var ch = plaintext.charAt(i);
		if (SAFECHARS.indexOf(ch) != -1) {
			encoded += ch;
		} else {
			var charCode = ch.charCodeAt(0);
			if (charCode > 255) {
				alert( "Unicode Character are not supported in URL" );
				encoded += "+";
			} else {
				encoded += "%";
				encoded += HEX.charAt((charCode >> 4) & 0xF);
				encoded += HEX.charAt(charCode & 0xF);
			}
		}
	}

return encoded;
}

// Modified to  handle XSS . Change the  url  with re-ecoded values
function go_url()
{
	decoded_url = decode_url("%2Fnbshomeredirector%2Easp");
	encoded_url = encode_url(decoded_url);
	location.replace(encoded_url);
}

function frametop()
{
  if (!(top === self))
  {
    document.write = '';
    setTimeout(function(){document.body.innerHTML='';},1);
    window.self.onload=function(evt){document.body.innerHTML='';};
    window.top.location = window.self.location;
  }
}

function check_popup()
{
    frametop();
	if (window.name == "SecurIDPopup") {
		alert('Authentication successful');
		window.close();
	} 
	if (window.name == "SecurIDPopupLogoff") {
		// Close this after 1.4 seconds
        setTimeout("window.close()", 1400);
	}
	else
    { 
        if ( true ) {
		    setTimeout("go_url()", 1 * 1000);
        }
    }
}
//-->
</script>
